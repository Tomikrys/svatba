{
  "name": "svatba3d",
  "version": "1.0.0",
  "description": "3D Wedding Cathedral Viewer",
  "type": "module",
  "scripts": {
    "build": "esbuild js/presentation.js --bundle --outfile=dist/presentation.bundle.js --format=esm --minify",
    "build:dev": "esbuild js/presentation.js --bundle --outfile=dist/presentation.bundle.js --format=esm --sourcemap",
    "build:editor": "esbuild js/main.js --bundle --outfile=dist/editor.bundle.js --format=esm --minify",
    "deploy": "npm run build && node scripts/deploy.js",
    "serve": "python3 -m http.server 8080"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "esbuild": "^0.20.0"
  },
  "dependencies": {
    "@tweenjs/tween.js": "^21.0.0",
    "three": "^0.162.0"
  }
}